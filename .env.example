# Alpaca API (paper trading)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_PAPER=true

# Polygon API (optional, for additional market data)
POLYGON_API_KEY=

# Strategy — Gap detection
GAP_THRESHOLD=2.0

# Strategy — Trend EMA periods
TREND_EMA_FAST=20
TREND_EMA_SLOW=50

# Strategy — Momentum candle filters
MOMENTUM_BODY_RATIO=0.7
MOMENTUM_WICK_MAX=0.15

# Strategy — Scale-out percentages (of position size)
SCALE_OUT_1=30
SCALE_OUT_2=50
SCALE_OUT_3=70

# Strategy — Risk management
STOP_LOSS_BUFFER=0.002
MAX_POSITIONS=3
RISK_PER_TRADE=0.02
DAILY_LOSS_LIMIT=0.05
TIME_STOP_HOUR=11

# Server
PORT=3001
